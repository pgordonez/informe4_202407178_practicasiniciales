import { Link, useNavigate, useLocation } from 'react-router-dom';

function Navbar() {
  const navigate = useNavigate();
  const location = useLocation();
  const usuario = JSON.parse(localStorage.getItem('usuario'));

  const cerrarSesion = () => {
    localStorage.removeItem('usuario');
    navigate('/');
  };

  const isActive = (path) => location.pathname === path ? 'nav-link active' : 'nav-link';

  return (
    <nav className="navbar">
      <div className="navbar-brand">🎓 Portal Universitario</div>
      <div className="navbar-links">
        {!usuario ? (
          <>
            <Link to="/" className={isActive('/')}>Login</Link>
            <Link to="/register" className={isActive('/register')}>Registro</Link>
          </>
        ) : (
          <>
            <Link to="/publicaciones" className={isActive('/publicaciones')}>Publicaciones</Link>
            <Link to="/usuarios" className={isActive('/usuarios')}>Usuarios</Link>
            <Link to="/perfil" className={isActive('/perfil')}>Perfil</Link>
            <button className="btn-logout" onClick={cerrarSesion}>Salir</button>
          </>
        )}
      </div>
    </nav>
  );
}

export default Navbar;
